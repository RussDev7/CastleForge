  <Import Project="$(MSBuildToolsPath)\Microsoft.CSharp.targets" />
  <!-- MSBuild autogen script to populate GameExe_SHA256 and DNACommon_SHA256 -->
  <!-- ========== Hash emission -> CoreHashes.cs ========== -->
  <UsingTask TaskName="WriteDNAHash" TaskFactory="CodeTaskFactory" AssemblyFile="$(MSBuildToolsPath)\Microsoft.Build.Tasks.Core.dll">
    <ParameterGroup>
      <GameInputFile ParameterType="System.String" Required="true" />
      <DnaInputFile ParameterType="System.String" Required="true" />
      <OutFile ParameterType="System.String" Required="true" />
      <Namespace ParameterType="System.String" Required="true" />
    </ParameterGroup>
    <Task>
      <!-- Assembly refs must be assemblies, not namespaces -->
      <Reference Include="System" />
      <Reference Include="System.Core" />
      <Reference Include="System.Security" />
      <Using Namespace="System" />
      <Using Namespace="System.IO" />
      <Using Namespace="System.Text" />
      <Using Namespace="System.Security.Cryptography" />
      <Code Type="Fragment" Language="cs"><![CDATA[
        Func<string,string> sha256Hex = (path) =>
        {
          if (!File.Exists(path)) return "";
          using (var sha = SHA256.Create())
          using (var fs = File.OpenRead(path))
          {
            var h = sha.ComputeHash(fs);
            return BitConverter.ToString(h).Replace("-", "");
          }
        };
  
        try
        {
          // Ensure output directory exists
          var outDir = Path.GetDirectoryName(OutFile);
          if (!string.IsNullOrEmpty(outDir))
            Directory.CreateDirectory(outDir);
  
          var gameHash = sha256Hex(GameInputFile);
          var dnaHash  = sha256Hex(DnaInputFile);
  
          if (string.IsNullOrEmpty(gameHash))
            Log.LogWarning("[EmitBaselineHashes] File not found (Game): " + GameInputFile + " — emitting empty GameExe_SHA256.");
  
          if (string.IsNullOrEmpty(dnaHash))
            Log.LogWarning("[EmitBaselineHashes] File not found (DNA):  " + DnaInputFile  + " — emitting empty DNACommon_SHA256.");
  
          string timestamp = DateTime.UtcNow.ToString("o");
          var sb = new StringBuilder();
          sb.AppendLine("/*");
          sb.AppendLine("SPDX-License-Identifier: GPL-3.0-or-later");
          sb.AppendLine("Copyright (c) 2025 RussDev7");
          sb.AppendLine("This file is part of https://github.com/RussDev7/CastleForge - see LICENSE for details.");
          sb.AppendLine("*/");
          sb.AppendLine();
          sb.AppendLine("// <auto-generated> DO NOT EDIT.");
          sb.AppendLine("// Emitted by EmitBaselineDNACommonHash at " + timestamp);
          sb.AppendLine("namespace " + Namespace + " {");
          sb.AppendLine("    internal static partial class CoreHashes {");
          sb.AppendLine("        public const string GameExe_SHA256   = \"" + gameHash + "\";");
          sb.AppendLine("        public const string DNACommon_SHA256 = \"" + dnaHash  + "\";");
          sb.AppendLine("    }");
          sb.AppendLine("}");
  
          File.WriteAllText(OutFile, sb.ToString(), Encoding.UTF8);
        }
        catch (Exception ex)
        {
          Log.LogErrorFromException(ex, /*showStackTrace*/ true);
          return false;
        }
        return true;
      ]]></Code>
    </Task>
  </UsingTask>
  <Target Name="EmitBaselineDNACommonHash" BeforeTargets="BeforeCompile">
    <PropertyGroup>
      <!-- Your tree: project -> ..\..\..\ -> repo root -->
      <GameBaseline>$(MSBuildProjectDirectory)\..\..\..\ReferenceAssemblies\Core\CastleMinerZ.exe</GameBaseline>
      <DNABaseline>$(MSBuildProjectDirectory)\..\..\..\ReferenceAssemblies\Core\DNA.Common.dll</DNABaseline>
      <!-- Output file (you chose to keep it in source under Integrity\Generated) -->
      <GenFile>Integrity\Generated\CoreHashes.cs</GenFile>
      <!-- Namespace for CoreHashes -->
      <CoreHashesNamespace>ModLoader</CoreHashesNamespace>
    </PropertyGroup>
    <Message Text="Hashing '$(GameBaseline)' and '$(DNABaseline)' -&gt; '$(GenFile)'" Importance="High" />
    <WriteDNAHash GameInputFile="$(GameBaseline)" DnaInputFile="$(DNABaseline)" OutFile="$(GenFile)" Namespace="$(CoreHashesNamespace)" />
    <ItemGroup>
      <Compile Include="$(GenFile)" />
    </ItemGroup>
  </Target>
