  <!-- ============================================================
       Custom Biomes: Compile each .cs into its own DLL.
       Output: $(OutputPath)\WorldGenPlus\CustomBiomes\*.dll
       ============================================================ -->
  <ItemGroup>
    <!-- Any .cs file in here becomes its own DLL (the custom target uses this) -->
    <CustomBiomeSource Include="WorldGen\Biomes\Custom\MyTestBiome.cs" />
    <!-- IMPORTANT:
       Keep them OUT of the real build, but INCLUDE them for design-time
       so VS/Roslyn can provide coloring + IntelliSense. -->
    <Compile Include="WorldGen\Biomes\Custom\*.cs" Condition="'$(DesignTimeBuild)'=='true'" />
    <Compile Remove="WorldGen\Biomes\Custom\*.cs" Condition="'$(DesignTimeBuild)'!='true'" />
  </ItemGroup>
  <ItemGroup />
  <Target Name="BuildCustomBiomes" AfterTargets="Build" Condition="'@(CustomBiomeSource)' != ''">
    <PropertyGroup>
      <!-- The main OutputPath already points at ...\Release\!Mods\ -->
      <CustomBiomesOutDir>$(OutputPath)WorldGenPlus\CustomBiomes\</CustomBiomesOutDir>
      <!-- Keep language consistent with the mod suite -->
      <CustomBiomesLangVersion Condition="'$(LangVersion)'!=''">$(LangVersion)</CustomBiomesLangVersion>
      <CustomBiomesLangVersion Condition="'$(LangVersion)'==''">7.3</CustomBiomesLangVersion>
    </PropertyGroup>
    <MakeDir Directories="$(CustomBiomesOutDir)" />
    <!-- Build a clean reference item list (avoid mixing strings + itemlists) -->
    <ItemGroup>
      <CustomBiomeReferences Include="@(ReferencePath)" />
      <!-- Only include the mod output if a biome references WorldGenPlus types -->
      <CustomBiomeReferences Include="$(TargetPath)" Condition="Exists('$(TargetPath)')" />
    </ItemGroup>
    <!-- Compile ONE dll per source file (MSBuild batching via %(CustomBiomeSource.*)) -->
    <Csc Sources="%(CustomBiomeSource.Identity)" TargetType="library" OutputAssembly="$(CustomBiomesOutDir)%(CustomBiomeSource.Filename).dll" LangVersion="$(CustomBiomesLangVersion)" DefineConstants="$(DefineConstants)" Optimize="$(Optimize)" DebugType="$(DebugType)" Platform="$(PlatformTarget)" AllowUnsafeBlocks="$(AllowUnsafeBlocks)" References="@(CustomBiomeReferences)" />
    <Message Importance="High" Text="Custom biomes built to: $(CustomBiomesOutDir)" />
  </Target>
